{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Streamcontrol MS",
  "version": "1.3.0",
  "identifier": "com.tuproyecto.scoreboard",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Streamcontrol MS",
        "width": 1240,
        "height": 810
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**/*"]
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "resources": [
      "../personajes"
    ]
  }
}
