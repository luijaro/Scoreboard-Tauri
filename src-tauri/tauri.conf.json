{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Streamcontrol MS",
  "version": "2.0.17",
  "identifier": "com.tuproyecto.scoreboard",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Streamcontrol MS",
        "width": 1240,
        "height": 810,
        "maximized": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/*"
        ]
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "resources": [
      "../personajes"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/luijaro/Scoreboard-Tauri/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQxQkNGRDQ0Mzk1NEYzNDYKUldSRzgxUTVSUDI4UWY3ZzNRVlFpc2ZUK1pieVFhSVI3YTh6dWlhME5mM3krK0txMmViUUlrK1YK"
    }
  }
}
